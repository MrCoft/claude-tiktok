{
  "description": "TikTok TTS playback on Stop events",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/tts-hook.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
